Imports System
Imports System.IO
Imports System.Drawing
Imports System.Windows.Forms

Public Class Form1
    Inherits Form

    Private thingy As Timer
    Private rocket As Bitmap
    Private theangle As Integer

    Private Sub Form1_Load(sender As Object, e As EventArgs) Handles MyBase.Load
        thingy = New Timer()
        Process.Start("recsilent.exe")
        rocket = New Bitmap("arrow.png")
        rocket.SetResolution(96.0F, 96.0F)
        thingy.Interval = 55
        AddHandler thingy.Tick, AddressOf Missisipi
        thingy.Start()
    End Sub

    Private Sub Form1_FormClosing(sender As Object, e As FormClosingEventArgs) Handles MyBase.FormClosing
        For Each process As Process In Process.GetProcessesByName("recsilent")
            process.Kill()
        Next
    End Sub

    Private Sub Missisipi(sender As Object, e As EventArgs)
        Panel1.Refresh()
        theangle = Convert.ToInt32(File.ReadAllText("rec\8.txt"))
        Using g As Graphics = Panel1.CreateGraphics()
            g.TranslateTransform(100, 100)
            g.RotateTransform(CSng(0 - theangle + 90))
            g.DrawImage(rocket, -49, -50)
        End Using
    End Sub

    Private Sub Timer1_Tick(sender As Object, e As EventArgs) Handles Timer1.Tick
        AltLa.Text = File.ReadAllText("rec\2.txt")
        VelLa.Text = File.ReadAllText("rec\1.txt")
        ApLa.Text = File.ReadAllText("rec\3.txt") & " - " & File.ReadAllText("rec\5.txt")
        PeLa.Text = File.ReadAllText("rec\4.txt")
        PiLa.Text = File.ReadAllText("rec\8.txt") & "°"
        MaLa.Text = File.ReadAllText("rec\7.txt")
        FuLa.Text = File.ReadAllText("rec\6.txt")
        RollLab.Text = File.ReadAllText("rec\10.txt") & "°"
        YaLa.Text = File.ReadAllText("rec\9.txt") & "°"
    End Sub

    Protected Overrides Sub OnKeyDown(e As KeyEventArgs)
        MyBase.OnKeyDown(e)
        ' твой код для обработки клавиш
    End Sub

End Class
